# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
DEPLOYMENT=local
NEXT_PUBLIC_TIMEZONE=client
NEXT_PUBLIC_APP_URL=http://localhost:3000

NEXT_PUBLIC_API_URL=http://127.0.0.1:8123/api/v1
NEXT_PUBLIC_IS_DEV_SITE=true

# -----------------------------------------------------------------------------
# Authentication (NextAuth.js)
# -----------------------------------------------------------------------------
# Possible auth flows: oauth2, credentials
NEXT_PUBLIC_AUTH_FLOW=oauth2
NEXTAUTH_URL=http://localhost:3000

GOOGLE_CLIENT_ID=scaffold.apps.googleusercontent.com
APPLE_CLIENT_ID=com.scaffold.dev

NEXT_PUBLIC_GA_MEASUREMENT_ID=
